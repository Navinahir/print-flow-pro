{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "watch": "vite build --watch",
        "dev:merchant": "concurrently -k -n vite,merchant -c \"#fdba74,#93c5fd\" \"vite\" \"php artisan serve --host=localhost --port=8001\"",
        "dev:all": "concurrently -k -n vite,mkt,merchant,admin -c \"#fdba74,#a7f3d0,#93c5fd,#c4b5fd\" \"vite\" \"php artisan serve --host=localhost --port=8000\" \"php artisan serve --host=localhost --port=8001\" \"php artisan serve --host=localhost --port=8002\""
    },
    "devDependencies": {
        "@tailwindcss/forms": "^0.5.2",
        "alpinejs": "^3.4.2",
        "autoprefixer": "^10.4.2",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^2.0.0",
        "postcss": "^8.4.31",
        "tailwindcss": "^3.1.0",
        "vite": "^7.0.7"
    },
    "dependencies": {
        "cropperjs": "^1.6.2",
        "sweetalert2": "^11.26.25"
    }
}
